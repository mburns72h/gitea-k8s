# Copy to values-secrets.yaml and fill in — never commit values-secrets.yaml
# Apply with: helm upgrade gitea-staging ... -f staging/values.yaml -f staging/values-secrets.yaml
gitea:
  config:
    "oauth2_client.authentik":
      CLIENT_ID: ""     # From Authentik staging gitea-staging application
      CLIENT_SECRET: "" # From Authentik staging gitea-staging application
