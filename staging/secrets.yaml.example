---
# Admin credentials
apiVersion: v1
kind: Secret
metadata:
  name: gitea-stage-admin
  namespace: gitea-stage
type: Opaque
stringData:
  username: gitea_admin
  password: "<admin-password>"
  email: "mburns72h+gitea-stage@gmail.com"
---
# Gitea internal secrets + Redis URLs + Authentik OAuth2 credentials
# Generate tokens with: gitea generate secret INTERNAL_TOKEN / SECRET_KEY / JWT_SECRET
apiVersion: v1
kind: Secret
metadata:
  name: gitea-stage-secrets
  namespace: gitea-stage
type: Opaque
stringData:
  internal_token: "<generate: gitea generate secret INTERNAL_TOKEN>"
  secret_key: "<generate: gitea generate secret SECRET_KEY>"
  lfs_jwt_secret: "<generate: gitea generate secret JWT_SECRET>"
  oauth2_jwt_secret: "<generate: gitea generate secret JWT_SECRET>"
  redis_password: "<random-password>"
  redis_session_url: "redis://:<redis-password>@gitea-stage-valkey-primary:6379/0?pool_size=100&idle_timeout=180s"
  redis_cache_url: "redis://:<redis-password>@gitea-stage-valkey-primary:6379/1?pool_size=100&idle_timeout=180s"
  redis_queue_url: "redis://:<redis-password>@gitea-stage-valkey-primary:6379/2?pool_size=100&idle_timeout=180s"
  authentik_client_id: "<from-vaultwarden: Homelab Secrets/Gitea>"
  authentik_client_secret: "<from-vaultwarden: Homelab Secrets/Gitea>"
  # Required by gitea.oauth existingSecret — same values as above, different key names expected by Helm chart
  key: "<same-as-authentik-client-id>"
  secret: "<same-as-authentik-client-secret>"
---
# PostgreSQL credentials (used by both the postgresql subchart and Gitea)
apiVersion: v1
kind: Secret
metadata:
  name: gitea-stage-postgresql
  namespace: gitea-stage
type: Opaque
stringData:
  postgres-password: "<postgres-superuser-password>"
  password: "<gitea-user-password>"
  username: "gitea"
  database: "gitea"
