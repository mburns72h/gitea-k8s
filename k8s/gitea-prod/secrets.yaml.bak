---
# PostgreSQL HA secrets
# The postgresql-ha chart expects these keys
apiVersion: v1
kind: Secret
metadata:
  name: gitea-pg-ha-secrets
  namespace: gitea
type: Opaque
stringData:
  # PostgreSQL passwords (change these!)
  postgresql-password: "CHANGE_ME_postgres_admin_password"
  password: "CHANGE_ME_gitea_db_password"
  repmgr-password: "CHANGE_ME_repmgr_password"
---
# Pgpool custom users secret (required for app user authentication)
apiVersion: v1
kind: Secret
metadata:
  name: gitea-pgpool-custom-users
  namespace: gitea
type: Opaque
stringData:
  # Format: username:md5<md5(password + username)>
  # For giteauser, generate with: echo -n "passwordgiteauser" | md5sum
  # Example: giteauser:md5a1234567890abcdef1234567890abcd
  usernames: "giteauser"
  passwords: "CHANGE_ME_gitea_db_password"
---
# Database connection secret for Gitea application
apiVersion: v1
kind: Secret
metadata:
  name: gitea-db-app
  namespace: gitea
type: Opaque
stringData:
  username: "giteauser"
  password: "CHANGE_ME_gitea_db_password"
---
# Gitea application secrets
# Generate new secrets with: openssl rand -base64 32
apiVersion: v1
kind: Secret
metadata:
  name: gitea-secrets
  namespace: gitea
type: Opaque
stringData:
  # Generate with: gitea generate secret INTERNAL_TOKEN
  # Or use: openssl rand -base64 105 | tr -d '\n'
  internal_token: "CHANGE_ME_generate_with_gitea_generate_secret_INTERNAL_TOKEN"

  # Generate with: gitea generate secret SECRET_KEY
  # Or use: openssl rand -base64 32
  secret_key: "CHANGE_ME_generate_with_gitea_generate_secret_SECRET_KEY"

  # Generate with: gitea generate secret JWT_SECRET
  # Or use: openssl rand -base64 32
  lfs_jwt_secret: "CHANGE_ME_generate_with_gitea_generate_secret_JWT_SECRET"

  # Generate with: gitea generate secret JWT_SECRET
  # Or use: openssl rand -base64 32
  oauth2_jwt_secret: "CHANGE_ME_generate_with_gitea_generate_secret_JWT_SECRET"
---
# Redis password secret
apiVersion: v1
kind: Secret
metadata:
  name: gitea-redis
  namespace: gitea
type: Opaque
stringData:
  redis-password: "CHANGE_ME_redis_password"
